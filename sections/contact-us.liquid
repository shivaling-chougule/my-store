{%- comment -%} sections/contact-us.liquid {%- endcomment -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Dosis:wght@500;700;800&display=swap" rel="stylesheet">

{%- liquid
  assign sid = section.id
  assign s = section.settings
  assign cu_form_id = 'ContactUs-form-' | append: sid
-%}

{%- style -%}
  #ContactUs-{{ sid }} {
    --cu-font: 'Dosis', sans-serif;
    --cu-form-bg: {{ s.form_bg_color }};
    --cu-heading-color: {{ s.heading_color }};
    --cu-subtitle-color: {{ s.subtitle_color }};
    --cu-input-text: {{ s.input_text_color }};
    --cu-input-border: {{ s.input_border_color }};
    --cu-input-focus: {{ s.input_focus_color }};
    --cu-btn-bg: {{ s.btn_bg_color }};
    --cu-btn-text: {{ s.btn_text_color }};
    --cu-btn-hover-bg: {{ s.btn_hover_bg_color }};
    --cu-banner-bg: {{ s.banner_bg_color }};
    --cu-banner-text: {{ s.banner_text_color }};
    --cu-banner-icon: {{ s.banner_icon_color }};
    --cu-form-pad-v: {{ s.form_padding_vertical }}px;
    --cu-form-pad-h: {{ s.form_padding_horizontal }}px;
    --cu-banner-pad-v: {{ s.banner_padding_vertical }}px;
    --cu-max-w: {{ s.max_content_width }}px;
    --cu-placeholder: {{ s.input_placeholder_color }};
    --cu-success-text: #2e7d32;
    --cu-success-bg: #e8f5e9;
    --cu-success-border: #c8e6c9;
    --cu-error-text: #c62828;
    --cu-error-bg: #ffebee;
    --cu-error-border: #ffcdd2;
  }

  /* ── Visually hidden (a11y labels) ── */
  #ContactUs-{{ sid }} .cu-visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Form Area ── */
  #ContactUs-{{ sid }} .cu-form-area {
    background: var(--cu-form-bg);
    padding: var(--cu-form-pad-v) var(--cu-form-pad-h);
  }

  #ContactUs-{{ sid }} .cu-inner {
    max-width: var(--cu-max-w);
    margin: 0 auto;
  }

  #ContactUs-{{ sid }} .cu-heading {
    font-family: var(--cu-font);
    font-weight: 800;
    font-size: 40px;
    line-height: 1.1;
    text-transform: uppercase;
    text-align: center;
    color: var(--cu-heading-color);
    margin: 0 0 12px;
  }

  #ContactUs-{{ sid }} .cu-subtitle {
    font-family: var(--cu-font);
    font-weight: 500;
    font-size: 16px;
    line-height: 1.5;
    text-align: center;
    color: var(--cu-subtitle-color);
    margin: 0 0 48px;
  }

  #ContactUs-{{ sid }} .cu-form {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  #ContactUs-{{ sid }} .cu-input,
  #ContactUs-{{ sid }} .cu-textarea {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--cu-input-border);
    border-radius: 0;
    padding: 12px 0;
    font-family: var(--cu-font);
    font-weight: 500;
    font-size: 16px;
    color: var(--cu-input-text);
    outline: none;
    transition: border-color 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  #ContactUs-{{ sid }} .cu-input::placeholder,
  #ContactUs-{{ sid }} .cu-textarea::placeholder {
    color: var(--cu-placeholder);
    opacity: 1;
  }

  #ContactUs-{{ sid }} .cu-input:focus,
  #ContactUs-{{ sid }} .cu-textarea:focus {
    border-bottom-color: var(--cu-input-focus);
  }

  #ContactUs-{{ sid }} .cu-textarea {
    resize: vertical;
    min-height: 140px;
  }

  #ContactUs-{{ sid }} .cu-submit {
    width: 100%;
    background: var(--cu-btn-bg);
    color: var(--cu-btn-text);
    font-family: var(--cu-font);
    font-weight: 700;
    font-size: 16px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: none;
    border-radius: 999px;
    padding: 18px 32px;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.2s ease;
    margin-top: 20px;
  }

  #ContactUs-{{ sid }} .cu-submit:hover,
  #ContactUs-{{ sid }} .cu-submit:focus-visible {
    background: var(--cu-btn-hover-bg);
    transform: translateY(-1px);
  }

  #ContactUs-{{ sid }} .cu-submit:focus-visible {
    outline: 2px solid var(--cu-btn-hover-bg);
    outline-offset: 3px;
  }

  #ContactUs-{{ sid }} .cu-form-success {
    font-family: var(--cu-font);
    font-weight: 500;
    font-size: 18px;
    text-align: center;
    color: var(--cu-success-text);
    padding: 24px;
    border: 1px solid var(--cu-success-border);
    border-radius: 8px;
    background: var(--cu-success-bg);
  }

  #ContactUs-{{ sid }} .cu-form-error {
    font-family: var(--cu-font);
    font-weight: 500;
    font-size: 14px;
    color: var(--cu-error-text);
    padding: 12px 16px;
    border: 1px solid var(--cu-error-border);
    border-radius: 8px;
    background: var(--cu-error-bg);
  }

  /* ── Info Banner ── */
  #ContactUs-{{ sid }} .cu-banner {
    background: var(--cu-banner-bg);
    padding: var(--cu-banner-pad-v) var(--cu-form-pad-h);
  }

  #ContactUs-{{ sid }} .cu-banner-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    text-align: center;
  }

  #ContactUs-{{ sid }} .cu-banner-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  #ContactUs-{{ sid }} .cu-banner-icon {
    color: var(--cu-banner-icon);
    width: 49px;
    height: 49px;
  }

  #ContactUs-{{ sid }} .cu-banner-icon svg {
    width: 100%;
    height: 100%;
  }

  #ContactUs-{{ sid }} .cu-banner-col-title {
    font-family: var(--cu-font);
    font-weight: 800;
    font-size: 32px;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--cu-banner-text);
    margin: 8px 0 0;
  }

  #ContactUs-{{ sid }} .cu-banner-col-detail {
    font-family: var(--cu-font);
    font-weight: 500;
    font-size: 20px;
    color: var(--cu-banner-text);
    margin: 0;
  }

  #ContactUs-{{ sid }} .cu-banner-col-detail a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  #ContactUs-{{ sid }} .cu-banner-col-detail a:hover {
    opacity: 0.8;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    #ContactUs-{{ sid }} .cu-banner-inner {
      gap: 32px;
    }

    #ContactUs-{{ sid }} .cu-banner-col-title {
      font-size: 28px;
    }
  }

  @media (max-width: 768px) {
    #ContactUs-{{ sid }} .cu-banner-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    #ContactUs-{{ sid }} .cu-heading {
      font-size: 32px;
    }

    #ContactUs-{{ sid }} .cu-banner-col-title {
      font-size: 26px;
    }

    #ContactUs-{{ sid }} .cu-banner-col-detail {
      font-size: 18px;
    }
  }

  @media (max-width: 390px) {
    #ContactUs-{{ sid }} .cu-form-area {
      padding: 40px 20px;
    }

    #ContactUs-{{ sid }} .cu-heading {
      font-size: 28px;
    }

    #ContactUs-{{ sid }} .cu-banner {
      padding: 40px 20px;
    }

    #ContactUs-{{ sid }} .cu-banner-col-title {
      font-size: 22px;
    }

    #ContactUs-{{ sid }} .cu-banner-col-detail {
      font-size: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #ContactUs-{{ sid }} .cu-submit,
    #ContactUs-{{ sid }} .cu-input,
    #ContactUs-{{ sid }} .cu-textarea,
    #ContactUs-{{ sid }} .cu-banner-col-detail a {
      transition: none;
    }
  }
{%- endstyle -%}

<div
  id="ContactUs-{{ sid }}"
  class="shopify-section-contact-us"
  role="region"
  aria-label="{{ s.heading | default: 'Contact Us' | escape }}"
>
  {%- comment -%} ── Form Area ── {%- endcomment -%}
  <div class="cu-form-area">
    <div class="cu-inner">
      {%- if s.heading != blank -%}
        <h2 class="cu-heading">{{ s.heading | escape }}</h2>
      {%- endif -%}

      {%- if s.subtitle != blank -%}
        <p class="cu-subtitle">{{ s.subtitle | escape }}</p>
      {%- endif -%}

      {%- form 'contact', id: cu_form_id, class: 'cu-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="cu-form-success" role="status" tabindex="-1">
            {{ s.success_message | escape }}
          </div>
        {%- else -%}
          {%- if form.errors -%}
            <div class="cu-form-error" role="alert" tabindex="-1">
              {%- for field in form.errors -%}
                {{ form.errors.translated_fields[field] | capitalize }}
                {{ form.errors.messages[field] }}.
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="cu-field">
            <label class="cu-visually-hidden" for="{{ cu_form_id }}-name">
              {{ s.label_name | escape }}
            </label>
            <input
              type="text"
              id="{{ cu_form_id }}-name"
              class="cu-input"
              name="contact[{{ 'contact.form.name' | t }}]"
              autocomplete="name"
              placeholder="{{ s.label_name | escape }}"
              value="{% if form.name %}{{ form.name | escape }}{% elsif customer %}{{ customer.name | escape }}{% endif %}"
            >
          </div>

          <div class="cu-field">
            <label class="cu-visually-hidden" for="{{ cu_form_id }}-email">
              {{ s.label_email | escape }}
            </label>
            <input
              type="email"
              id="{{ cu_form_id }}-email"
              class="cu-input"
              name="contact[email]"
              autocomplete="email"
              spellcheck="false"
              autocapitalize="off"
              aria-required="true"
              {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
              placeholder="{{ s.label_email | escape }}"
              value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}"
            >
          </div>

          <div class="cu-field">
            <label class="cu-visually-hidden" for="{{ cu_form_id }}-body">
              {{ s.label_message | escape }}
            </label>
            <textarea
              id="{{ cu_form_id }}-body"
              class="cu-textarea"
              name="contact[{{ 'contact.form.message' | t }}]"
              rows="6"
              placeholder="{{ s.label_message | escape }}"
            >{% if form.body %}{{ form.body | escape }}{% endif %}</textarea>
          </div>

          <button type="submit" class="cu-submit">
            {{ s.btn_label | escape }}
          </button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>

  {%- comment -%} ── Info Banner ── {%- endcomment -%}
  <div class="cu-banner" role="complementary" aria-label="Contact information">
    <div class="cu-banner-inner">

      {%- comment -%} Column 1: Phone {%- endcomment -%}
      <div class="cu-banner-col">
        <span class="cu-banner-icon" aria-hidden="true">
          <svg viewBox="0 0 49 49" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M44.08 34.54a3.06 3.06 0 0 0-2.37-1.12c-2.06-.1-4.07-.5-5.97-1.18a3.06 3.06 0 0 0-3.12.7l-3.26 3.26a24.5 24.5 0 0 1-10.78-10.78l3.26-3.26a3.06 3.06 0 0 0 .7-3.12 19.7 19.7 0 0 1-1.18-5.97 3.06 3.06 0 0 0-3.06-2.82h-5.72a3.06 3.06 0 0 0-3.06 3.26c.68 11.06 5.14 21.22 12.56 28.64s17.58 11.88 28.64 12.56a3.06 3.06 0 0 0 3.26-3.06V35a3.06 3.06 0 0 0-.91-2.46z" fill="currentColor"/>
          </svg>
        </span>
        <p class="cu-banner-col-title">{{ s.col1_title | escape }}</p>
        <p class="cu-banner-col-detail">
          <a href="tel:{{ s.phone | escape }}">
            {{ s.phone | escape }}
          </a>
        </p>
      </div>

      {%- comment -%} Column 2: Questions {%- endcomment -%}
      <div class="cu-banner-col">
        <span class="cu-banner-icon" aria-hidden="true">
          <svg viewBox="0 0 49 49" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24.5" cy="24.5" r="16.33" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <path d="M19.5 19.83a5.5 5.5 0 0 1 10.68 1.84c0 3.66-5.5 5.5-5.5 5.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            <circle cx="24.5" cy="35" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="2"/>
          </svg>
        </span>
        <p class="cu-banner-col-title">{{ s.col2_title | escape }}</p>
        <p class="cu-banner-col-detail">
          {%- if s.faq_url != blank -%}
            <a href="{{ s.faq_url | escape }}">{{ s.faq_label | escape }}</a>
          {%- else -%}
            {{ s.faq_label | escape }}
          {%- endif -%}
        </p>
      </div>

      {%- comment -%} Column 3: Email {%- endcomment -%}
      <div class="cu-banner-col">
        <span class="cu-banner-icon" aria-hidden="true">
          <svg viewBox="0 0 49 49" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="12" width="37" height="25" rx="2" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <path d="M6 14l18.5 13L43 14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          </svg>
        </span>
        <p class="cu-banner-col-title">{{ s.col3_title | escape }}</p>
        <p class="cu-banner-col-detail">
          <a href="mailto:{{ s.email | escape }}">{{ s.email | escape }}</a>
        </p>
      </div>

    </div>
  </div>
</div>

<script>
  (function () {
    var SECTION_ID = '{{ sid }}';

    function init() {
      var root = document.getElementById('ContactUs-' + SECTION_ID);
      if (!root) return;

      var focusTarget = root.querySelector('[tabindex="-1"]');
      if (focusTarget) {
        focusTarget.focus({ preventScroll: true });
      }
    }

    function onSectionEvent(e, cb) {
      if (e.detail && e.detail.sectionId === SECTION_ID) cb();
    }

    document.addEventListener('shopify:section:load', function (e) {
      onSectionEvent(e, init);
    });

    init();
  })();
</script>

{% schema %}
{
  "name": "Contact Us",
  "class": "shopify-section-contact-us",
  "settings": [
    { "type": "header", "content": "Form Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "CONTACT US" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Feel free to reach out to us incase of any queries" },
    { "type": "text", "id": "label_name", "label": "Name placeholder", "default": "Full name" },
    { "type": "text", "id": "label_email", "label": "Email placeholder", "default": "Email" },
    { "type": "text", "id": "label_message", "label": "Message placeholder", "default": "Message" },
    { "type": "text", "id": "btn_label", "label": "Submit button text", "default": "SUBMIT" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thanks for contacting us! We'll be in touch shortly." },

    { "type": "header", "content": "Form Colors" },
    { "type": "color", "id": "form_bg_color", "label": "Form background", "default": "#FFFFFF" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#000000" },
    { "type": "color", "id": "subtitle_color", "label": "Subtitle color", "default": "#5F5F5F" },
    { "type": "color", "id": "input_text_color", "label": "Input text color", "default": "#5F5F5F" },
    { "type": "color", "id": "input_border_color", "label": "Input underline", "default": "#CCCCCC" },
    { "type": "color", "id": "input_placeholder_color", "label": "Placeholder color", "default": "#999999" },
    { "type": "color", "id": "input_focus_color", "label": "Input focus underline", "default": "#FE534C" },
    { "type": "color", "id": "btn_bg_color", "label": "Button background", "default": "#FE534C" },
    { "type": "color", "id": "btn_text_color", "label": "Button text", "default": "#FFFFFF" },
    { "type": "color", "id": "btn_hover_bg_color", "label": "Button hover", "default": "#e63e37" },

    { "type": "header", "content": "Info Banner" },
    { "type": "text", "id": "col1_title", "label": "Column 1 title", "default": "CALL US" },
    { "type": "text", "id": "phone", "label": "Phone number", "default": "(888) 780-0864" },
    { "type": "text", "id": "col2_title", "label": "Column 2 title", "default": "QUESTIONS" },
    { "type": "text", "id": "faq_label", "label": "FAQ link text", "default": "Visit FAQ" },
    { "type": "url", "id": "faq_url", "label": "FAQ page URL" },
    { "type": "text", "id": "col3_title", "label": "Column 3 title", "default": "EMAIL US" },
    { "type": "text", "id": "email", "label": "Email address", "default": "ftisales@firetheimagination.ca" },

    { "type": "header", "content": "Banner Colors" },
    { "type": "color", "id": "banner_bg_color", "label": "Banner background", "default": "#FE534C" },
    { "type": "color", "id": "banner_text_color", "label": "Banner text", "default": "#FFFFFF" },
    { "type": "color", "id": "banner_icon_color", "label": "Banner icons", "default": "#FFFFFF" },

    { "type": "header", "content": "Layout" },
    {
      "type": "range", "id": "form_padding_vertical", "label": "Form vertical padding",
      "min": 40, "max": 160, "step": 8, "unit": "px", "default": 80
    },
    {
      "type": "range", "id": "form_padding_horizontal", "label": "Form horizontal padding",
      "min": 16, "max": 120, "step": 4, "unit": "px", "default": 40
    },
    {
      "type": "range", "id": "banner_padding_vertical", "label": "Banner vertical padding",
      "min": 40, "max": 160, "step": 8, "unit": "px", "default": 72
    },
    {
      "type": "range", "id": "max_content_width", "label": "Max form width",
      "min": 400, "max": 1200, "step": 40, "unit": "px", "default": 680
    }
  ],
  "presets": [
    {
      "name": "Contact Us",
      "category": "Pages"
    }
  ]
}
{% endschema %}
