      "blocks": [
        { "type": "faq_category", "settings": { "category_name": "General" } },
        { "type": "faq_item", "settings": { "question": "What is Fire the Imagination?", "answer": "<p>Fire the Imagination is a wholesale toy distributor specializing in unique, high-quality toys and gifts.</p>" } },
